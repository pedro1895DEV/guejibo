# Environment Variables configuration example.
# DO NOT place actual secrets in this file. Copy this file to .env and configure.

# --- Security and Authentication ---
# Secret for signing JWT tokens. In production, use a long, random, secure string.
JWT_SECRET="your_jwt_secret_here"
# Secret for signing express-session cookies.
SESSION_SECRET="your_session_secret_here"

# --- Database ---
# Database connection settings.
DB_HOST="localhost"
DB_PORT=3306
DB_NAME="guejibo"
DB_USER="root"
DB_PASS="password"
DB_DIALECT="mariadb"

# --- OAuth (Google) ---
# OAuth 2.0 credentials obtained from Google Cloud Console.
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# --- URLs and CORS ---
# Base URL for the backend API.
API_URL="http://localhost:3000"
# Base URL for the frontend application.
CLIENT_URL="http://localhost:4200"
# Allowed origins for CORS (comma-separated for multiple origins).
CORS_ORIGIN="http://localhost:4200"

# --- Server ---
# The port the Node app will listen on.
PORT=3000
